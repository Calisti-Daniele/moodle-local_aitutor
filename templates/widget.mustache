{{!
    @template local_aitutor/widget

    Widget floating dell'AI Assistant personale.
    Viene iniettato in ogni pagina Moodle tramite hook.

    Context variables:
    * sessionid (int)
    * messages (array) - Storia messaggi
    * welcome_message (string|null)
    * suggestions (array) - Domande suggerite
    * str_* - Stringhe UI
}}

{{! ── WIDGET CONTAINER ───────────────────────────────── }}
<div id="local-aitutor-widget"
     data-sessionid="{{sessionid}}"
     data-userid="{{userid}}"
     data-sesskey="{{sesskey}}"
     data-wwwroot="{{wwwroot}}"
     aria-label="{{str_title}}"
     role="complementary">

    {{! ── BUBBLE (widget chiuso) ─────────────────────── }}
    <button class="aitutor-bubble"
            id="aitutor-bubble-btn"
            aria-label="{{str_open}}"
            aria-expanded="false"
            aria-controls="aitutor-panel">
        <span class="aitutor-bubble-icon aitutor-bubble-icon--open">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" aria-hidden="true">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1
                         2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
        </span>
        <span class="aitutor-bubble-icon aitutor-bubble-icon--close d-none">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" aria-hidden="true">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </span>
        <span class="aitutor-bubble-pulse" aria-hidden="true"></span>
    </button>

    {{! ── PANEL (widget aperto) ──────────────────────── }}
    <div class="aitutor-panel"
         id="aitutor-panel"
         role="dialog"
         aria-modal="false"
         aria-label="{{str_title}}"
         hidden>

        {{! Header }}
        <div class="aitutor-panel-header">
            <div class="aitutor-panel-header-left">
                <div class="aitutor-ai-avatar" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2a2 2 0 0 1 2 2c0 .74-.4 1.39-1
                                 1.73V7h1a7 7 0 0 1 7 7H3a7 7 0 0 1
                                 7-7h1V5.73A2 2 0 0 1 10 4a2 2 0 0 1
                                 2-2M5 14v1a7 7 0 0 0 14 0v-1H5M3
                                 21h18v2H3v-2z"/>
                    </svg>
                </div>
                <div>
                    <div class="aitutor-panel-title">{{str_title}}</div>
                    <div class="aitutor-panel-status">
                        <span class="aitutor-status-dot" aria-hidden="true"></span>
                        <span class="aitutor-status-text">Online</span>
                    </div>
                </div>
            </div>
            <div class="aitutor-panel-header-right">
                <button class="aitutor-btn-icon aitutor-btn-clear"
                        data-confirm="{{str_clear_confirm}}"
                        title="{{str_clear}}"
                        aria-label="{{str_clear}}">
                    <svg viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2"
                         aria-hidden="true">
                        <polyline points="3 6 5 6 21 6"/>
                        <path d="M19 6l-1 14H6L5 6"/>
                        <path d="M10 11v6M14 11v6"/>
                    </svg>
                </button>
                <button class="aitutor-btn-icon aitutor-btn-close"
                        title="{{str_close}}"
                        aria-label="{{str_close}}">
                    <svg viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2"
                         aria-hidden="true">
                        <line x1="18" y1="6" x2="6" y2="18"/>
                        <line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            </div>
        </div>

        {{! Messages area }}
        <div class="aitutor-messages"
             id="aitutor-messages"
             role="log"
             aria-live="polite"
             aria-label="Chat messages">

            {{! Messaggio benvenuto }}
            {{#welcome_message}}
            <div class="aitutor-message aitutor-message--assistant
                        aitutor-message--welcome">
                <div class="aitutor-msg-avatar" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2a2 2 0 0 1 2 2c0 .74-.4
                                 1.39-1 1.73V7h1a7 7 0 0 1 7
                                 7H3a7 7 0 0 1 7-7h1V5.73A2 2
                                 0 0 1 10 4a2 2 0 0 1 2-2z"/>
                    </svg>
                </div>
                <div class="aitutor-msg-bubble">
                    {{welcome_message}}
                </div>
            </div>
            {{/welcome_message}}

            {{! Suggerimenti domande }}
            {{#suggestions}}
            <div class="aitutor-suggestions">
                {{#.}}
                <button class="aitutor-suggestion-btn">{{text}}</button>
                {{/.}}
            </div>
            {{/suggestions}}

            {{! Messaggi esistenti }}
            {{#messages}}
            <div class="aitutor-message aitutor-message--{{role}}">
                {{#is_assistant}}
                <div class="aitutor-msg-avatar" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2a2 2 0 0 1 2 2c0 .74-.4
                                 1.39-1 1.73V7h1a7 7 0 0 1 7
                                 7H3a7 7 0 0 1 7-7h1V5.73A2 2
                                 0 0 1 10 4a2 2 0 0 1 2-2z"/>
                    </svg>
                </div>
                {{/is_assistant}}
                <div class="aitutor-msg-bubble">
                    {{{content}}}
                </div>
            </div>
            {{/messages}}

            {{! Thinking indicator }}
            <div class="aitutor-message aitutor-message--assistant
                        aitutor-thinking d-none"
                 id="aitutor-thinking"
                 aria-hidden="true">
                <div class="aitutor-msg-avatar" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2a2 2 0 0 1 2 2c0 .74-.4
                                 1.39-1 1.73V7h1a7 7 0 0 1 7
                                 7H3a7 7 0 0 1 7-7h1V5.73A2 2
                                 0 0 1 10 4a2 2 0 0 1 2-2z"/>
                    </svg>
                </div>
                <div class="aitutor-msg-bubble">
                    <div class="aitutor-dots" aria-hidden="true">
                        <span></span><span></span><span></span>
                    </div>
                    <span class="sr-only">{{str_thinking}}</span>
                </div>
            </div>

        </div>

        {{! Error box }}
        <div class="aitutor-error d-none"
             id="aitutor-error"
             role="alert">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span class="aitutor-error-text">{{str_error}}</span>
        </div>

        {{! Input area }}
        <div class="aitutor-input-area">
            <div class="aitutor-input-row">
                <label for="aitutor-input" class="sr-only">
                    {{str_placeholder}}
                </label>
                <textarea id="aitutor-input"
                          class="aitutor-input"
                          placeholder="{{str_placeholder}}"
                          rows="1"
                          maxlength="4000"
                          aria-multiline="true"></textarea>
                <button class="aitutor-btn-send"
                        id="aitutor-send-btn"
                        aria-label="{{str_send}}">
                    <svg viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2"
                         aria-hidden="true">
                        <line x1="22" y1="2" x2="11" y2="13"/>
                        <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                    </svg>
                </button>
            </div>
            <div class="aitutor-input-hint">
                Enter to send · Shift+Enter for new line
            </div>
        </div>

    </div>
</div>